#!/usr/bin/env bash
# vim: set filetype=sh :

# @describe ULP - URL Line Processor for cleaning, deduplicating, and converting credential files
# @version 2.0.0

# @cmd Clean and normalize credential files by standardizing domain formats
# @arg input-file! "Input file or directory to process (recursively processes directories)" [string]
# @arg output-file "Output file or directory for cleaned results (defaults to input_processed)" [string]
clean() {
  # Set default output if not provided
  if [[ -z "$argc_output_file" ]]; then
    if [[ -d "$argc_input_file" ]]; then
      argc_output_file="${argc_input_file}_processed"
    else
      local dir=$(dirname "$argc_input_file")
      local base=$(basename "$argc_input_file" | sed 's/\.[^.]*$//')
      argc_output_file="${dir}/${base}_processed.txt"
    fi
  fi
  if [[ ! -f "$argc_input_file" && ! -d "$argc_input_file" ]]; then
    echo "Error: Input file or directory '$argc_input_file' not found" >&2
    exit 1
  fi

  process_file() {
    local input_file="$1"
    local output_file="$2"
    
    echo "Cleaning: $input_file -> $output_file" >&2
    
    perl -ne '
          next unless /[:|]/;
          s/\|/:/g;
          chomp;
          s/\r//g;
          s/\n//g;
          $_ .= "\n";
          print if s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|;
      ' "$input_file" >"$output_file"
  }

  process_directory() {
    local input_dir="$1"
    local output_dir="$2"
    
    echo "Processing directory recursively: $input_dir -> $output_dir" >&2
    
    mkdir -p "$output_dir"
    
    find "$input_dir" -type f -print0 | while IFS= read -r -d '' file; do
      local rel_path="${file#$input_dir/}"
      local rel_dir=$(dirname "$rel_path")
      local filename=$(basename "$rel_path")
      local base_name="${filename%.*}"
      local extension="${filename##*.}"
      
      if [[ "$rel_dir" == "." ]]; then
        local output_file="$output_dir/${base_name}_cleaned.${extension}"
      else
        mkdir -p "$output_dir/$rel_dir"
        local output_file="$output_dir/$rel_dir/${base_name}_cleaned.${extension}"
      fi
      
      process_file "$file" "$output_file"
    done
  }

  if [[ -d "$argc_input_file" ]]; then
    process_directory "$argc_input_file" "$argc_output_file"
    echo "Directory processing completed: $argc_input_file -> $argc_output_file"
  else
    process_file "$argc_input_file" "$argc_output_file"
    echo "Cleaned file: $argc_output_file"
  fi

  echo "Lines not matching format were ignored"
}

# @cmd Deduplicate credential files with optional duplicate output
# @arg input-file! "Input file or directory to process (recursively processes directories)" [string]
# @arg output-file "Output file or directory for deduplicated results (defaults to input_processed)" [string]
# @option -d --dupes-file "Output duplicate lines to this file" [string]
dedupe() {
  # Set default output if not provided
  if [[ -z "$argc_output_file" ]]; then
    if [[ -d "$argc_input_file" ]]; then
      argc_output_file="${argc_input_file}_processed"
    else
      local dir=$(dirname "$argc_input_file")
      local base=$(basename "$argc_input_file" | sed 's/\.[^.]*$//')
      argc_output_file="${dir}/${base}_processed.txt"
    fi
  fi
  if [[ ! -f "$argc_input_file" && ! -d "$argc_input_file" ]]; then
    echo "Error: Input file or directory '$argc_input_file' not found" >&2
    exit 1
  fi

  process_file() {
    local input_file="$1"
    local output_file="$2"
    local dupes_file="$3"
    
    echo "Deduplicating: $input_file -> $output_file" >&2
    
    if [[ -n "$dupes_file" ]]; then
      perl -ne '
              next unless /[:|]/;
              s/\|/:/g;
              chomp;
              s/\r//g;
              s/\n//g;
              $_ .= "\n";
              if (s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|) {
                  if ($seen{$_}++) {
                      print STDERR $_
                  } else {
                      print $_
                  }
              }
          ' "$input_file" >"$output_file" 2>"$dupes_file"
    else
      perl -ne '
              next unless /[:|]/;
              s/\|/:/g;
              chomp;
              s/\r//g;
              s/\n//g;
              $_ .= "\n";
              if (s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|) {
                  print unless $seen{$_}++;
              }
          ' "$input_file" >"$output_file"
    fi
  }

  process_directory() {
    local input_dir="$1"
    local output_dir="$2"
    local dupes_file_base="$3"
    
    echo "Processing directory recursively: $input_dir -> $output_dir" >&2
    
    mkdir -p "$output_dir"
    
    find "$input_dir" -type f -print0 | while IFS= read -r -d '' file; do
      local rel_path="${file#$input_dir/}"
      local rel_dir=$(dirname "$rel_path")
      local filename=$(basename "$rel_path")
      local base_name="${filename%.*}"
      local extension="${filename##*.}"
      
      if [[ "$rel_dir" == "." ]]; then
        local output_file="$output_dir/${base_name}_deduped.${extension}"
        local current_dupes_file=""
        if [[ -n "$dupes_file_base" ]]; then
          current_dupes_file="$output_dir/${base_name}_dupes.${extension}"
        fi
      else
        mkdir -p "$output_dir/$rel_dir"
        local output_file="$output_dir/$rel_dir/${base_name}_deduped.${extension}"
        local current_dupes_file=""
        if [[ -n "$dupes_file_base" ]]; then
          current_dupes_file="$output_dir/$rel_dir/${base_name}_dupes.${extension}"
        fi
      fi
      
      process_file "$file" "$output_file" "$current_dupes_file"
    done
  }

  if [[ -d "$argc_input_file" ]]; then
    if [[ -n "$argc_dupes_file" ]]; then
      echo "Warning: --dupes-file option ignored when processing directories (individual dupes files created per input file)" >&2
    fi
    
    process_directory "$argc_input_file" "$argc_output_file" "$argc_dupes_file"
    
    echo "Directory processing completed: $argc_input_file -> $argc_output_file"
  else
    if [[ -n "$argc_dupes_file" ]]; then
      process_file "$argc_input_file" "$argc_output_file" "$argc_dupes_file"
      
      echo "Deduplicated file: $argc_output_file"
      echo "Duplicate lines saved to: $argc_dupes_file"
      echo "Total duplicates removed: $(wc -l <"$argc_dupes_file")"
    else
      process_file "$argc_input_file" "$argc_output_file" ""
      
      echo "Deduplicated file: $argc_output_file"
      echo "Duplicates removed (use --dupes-file to save duplicates to a file)"
    fi
  fi

  echo "Lines not matching format were ignored"
}

# @cmd Convert cleaned credential files to NDJSON/JSONL format for Meilisearch indexing
# @arg input-file! "Input file or directory to process (recursively processes directories)" [string]
# @option -j --json-file "JSON metadata file (optional)" [string]
# @option -c --channel-name "Telegram channel name (optional)" [string]
# @option -a --channel-at "Telegram channel @ handle (optional)" [string]
jsonl() {
  if [[ ! -f "$argc_input_file" && ! -d "$argc_input_file" ]]; then
    echo "Error: Input file or directory '$argc_input_file' not found" >&2
    exit 1
  fi

  # Auto-detect JSON file if not provided and input is a directory
  if [[ -z "$argc_json_file" && -d "$argc_input_file" ]]; then
    local input_dir_name=$(basename "$argc_input_file")
    local parent_dir=$(dirname "$argc_input_file")
    local auto_json_file="${parent_dir}/${input_dir_name}.json"
    
    if [[ -f "$auto_json_file" ]]; then
      argc_json_file="$auto_json_file"
      echo "Auto-detected JSON file: $auto_json_file" >&2
    fi
  fi

  declare -A channel_metadata

  process_telegram_json() {
    local json_file="$1"

    if [[ -n "$json_file" && -f "$json_file" ]]; then
      if ! jq empty "$json_file" 2>/dev/null; then
        echo "Warning: JSON file '$json_file' is not valid JSON, attempting to fix..." >&2

        error_msg=$(jq empty "$json_file" 2>&1 || true)

        if [[ "$error_msg" == *"Invalid numeric literal"* ]]; then
          echo "This appears to be an issue with numeric values in the JSON. Attempting to pre-process the file..." >&2

          local temp_file=$(mktemp)
          sed 's/Infinity/null/g' "$json_file" >"$temp_file"

          if jq empty "$temp_file" 2>/dev/null; then
            echo "Pre-processing successful! Using fixed JSON file." >&2
            json_file="$temp_file"
          else
            rm "$temp_file"
            echo "Pre-processing failed. Will try to extract metadata anyway." >&2
          fi
        fi
      fi

      channel_id=$(jq -r 'keys[0]' "$json_file" 2>/dev/null || echo "")

      if [[ -n "$channel_id" && "$channel_id" != "null" ]]; then
        channel_metadata["id"]=$channel_id

        while IFS= read -r message; do
          file_name=$(echo "$message" | jq -r '.file // empty' 2>/dev/null)
          if [[ -n "$file_name" ]]; then
            base_input=$(basename "$argc_input_file")
            if [[ "$file_name" == *"$base_input"* ]] || [[ "$base_input" == *"$(echo "$file_name" | sed 's/🔒 //' | sed 's/ - @.*//')"* ]]; then
              channel_metadata["date"]=$(echo "$message" | jq -r '.raw.Date // ""' 2>/dev/null)
              channel_metadata["message_content"]=$(echo "$message" | jq -r '.raw.Message // ""' 2>/dev/null)
              channel_metadata["message_id"]=$(echo "$message" | jq -r '.raw.ID // ""' 2>/dev/null)

              if [[ -n "${temp_file:-}" && -f "${temp_file:-}" ]]; then
                rm -f "$temp_file"
              fi

              return 0
            fi
          fi
        done < <(jq -r '.[] | .messages[]? // empty' "$json_file" 2>/dev/null)

        if [[ -n "${temp_file:-}" && -f "${temp_file:-}" ]]; then
          rm -f "$temp_file"
        fi
      fi
    fi

    return 0
  }

  create_ndjson() {
    local input_file="$1"

    local original_filename
    original_filename=$(basename "$input_file")

    local ndjson_base="${original_filename%.*}_ms"

    local channel_name="${argc_channel_name:-}"
    local channel_at="${argc_channel_at:-}"

    if [[ -z "$channel_name" ]]; then
      if [[ "$original_filename" =~ @([^-]+) ]]; then
        channel_at="@${BASH_REMATCH[1]}"
        channel_name="${BASH_REMATCH[1]}"
      fi
    fi

    local post_date=""
    if [[ -n "${channel_metadata[date]}" && "${channel_metadata[date]}" != "null" ]]; then
      post_date=$(date -d "@${channel_metadata[date]}" -Iseconds 2>/dev/null || echo "${channel_metadata[date]}")
    fi

    echo "Creating NDJSON files with base name: ${ndjson_base}_*.jsonl" >&2
    echo "Processing input file: $input_file" >&2

    # Export metadata as environment variables to avoid shell escaping issues
    export ULP_ORIGINAL_FILENAME="$original_filename"
    export ULP_NDJSON_BASE="$ndjson_base"
    export ULP_CHANNEL_ID="$channel_id"
    export ULP_CHANNEL_NAME="$channel_name"
    export ULP_CHANNEL_AT="$channel_at"
    export ULP_POST_DATE="$post_date"
    export ULP_MESSAGE_CONTENT="${channel_metadata[message_content]:-}"
    export ULP_MESSAGE_ID="${channel_metadata[message_id]:-}"

    perl -ne '
          BEGIN {
              use JSON;
              use POSIX qw(strftime);
              use Encode qw(encode_utf8);

              my $file_counter = 1;
              my $current_file_size = 0;
              my $max_size = 100 * 1024 * 1024; # 100MB 
              my $line_count = 0;
              my $valid_line_count = 0;

              my $original_filename = $ENV{ULP_ORIGINAL_FILENAME} || "";
              my $ndjson_base = $ENV{ULP_NDJSON_BASE} || "";
              my $channel_id = $ENV{ULP_CHANNEL_ID} || "";
              my $channel_name = $ENV{ULP_CHANNEL_NAME} || "";
              my $channel_at = $ENV{ULP_CHANNEL_AT} || "";
              my $post_date = $ENV{ULP_POST_DATE} || "";
              my $message_content = $ENV{ULP_MESSAGE_CONTENT} || "";
              my $message_id = $ENV{ULP_MESSAGE_ID} || "";

              my $current_ndjson_file = sprintf("%s_%03d.jsonl", $ndjson_base, $file_counter);
              open(my $ndjson_fh, ">:utf8", $current_ndjson_file) or die "Cannot open $current_ndjson_file: $!";
              print STDERR "Created NDJSON file: $current_ndjson_file\n";

              sub new_file {
                  close($main::ndjson_fh) if $main::ndjson_fh;
                  $main::file_counter++;
                  my $new_file = sprintf("%s_%03d.jsonl", $ndjson_base, $main::file_counter);
                  open($main::ndjson_fh, ">:utf8", $new_file) or die "Cannot open $new_file: $!";
                  $main::current_file_size = 0;
                  print STDERR "Created new file: $new_file\n";
              }

              $main::ndjson_fh = $ndjson_fh;
              $main::current_file_size = $current_file_size;
              $main::max_size = $max_size;
              $main::original_filename = $original_filename;
              $main::channel_id = $channel_id;
              $main::channel_name = $channel_name;
              $main::channel_at = $channel_at;
              $main::post_date = $post_date;
              $main::message_content = $message_content;
              $main::message_id = $message_id;
              $main::ndjson_base = $ndjson_base;
              $main::file_counter = $file_counter;
              $main::line_count = $line_count;
              $main::valid_line_count = $valid_line_count;
          }

          $main::line_count++;

          next unless /[:|]/;

          s/\|/:/g;
          chomp;
          s/\r//g;
          s/\n//g;

          my $original_line = $_;
          my $cleaned_line = $_;

          if ($cleaned_line =~ /^(https?:\/\/)/) {
              $cleaned_line =~ s|^(https?://)(www\.)?([^/:]+)(.*?):|$3$4:|;
          } elsif ($cleaned_line =~ /^www\./) {
              $cleaned_line =~ s|^www\.([^/:]+)(.*?):|$1$2:|;
          } elsif ($cleaned_line =~ /^([^:\/]+(?:\.[^:\/]+)*)(\/ [^:]*)?:(.*)/) {
              my ($domain, $path, $rest) = ($1, $2 || "", $3);
              $cleaned_line = "$domain$path:$rest";
          } else {
              unless ($cleaned_line =~ /^[^:]+:[^:]+:/) {
                  next; 
              }
          }

          my @parts = split /:/, $cleaned_line;
          if (@parts < 3) {
              next; 
          }

          my $url_part = shift @parts;
          my $username = shift @parts;
          my $password = join(":", @parts); 

          next unless defined $username && defined $password &&
                     $username ne "" && $password ne "" &&
                     $username !~ /^\s*$/ && $password !~ /^\s*$/;

          my $full_url = $url_part;
          unless ($full_url =~ m|^https?://|) {
              $full_url = "https://" . $full_url;
          }

          my $doc = {
              url => $full_url,
              username => $username,
              password => $password,
              metadata => {
                  original_filename => $main::original_filename,
                  telegram_channel_id => $main::channel_id,
                  telegram_channel_name => $main::channel_name,
                  telegram_channel_at => $main::channel_at,
                  date_posted => $main::post_date,
                  message_content => $main::message_content,
                  message_id => $main::message_id
              }
          };

          my $json_line = encode_json($doc) . "\n";
          my $line_size = length(encode_utf8($json_line)); 

          if ($main::current_file_size + $line_size > $main::max_size && $main::current_file_size > 0) {
              new_file();
          }

          print {$main::ndjson_fh} $json_line;
          $main::current_file_size += $line_size;
          $main::valid_line_count++;

          END {
              close($main::ndjson_fh) if $main::ndjson_fh;
              print STDERR "Processed $main::line_count total lines, $main::valid_line_count valid credential lines\n";
          }
      ' <"$input_file"
  }

  process_directory() {
    local input_dir="$1"
    
    echo "Processing directory recursively: $input_dir" >&2
    
    find "$input_dir" -type f -print0 | while IFS= read -r -d '' file; do
      echo "Processing file: $file" >&2
      create_ndjson "$file"
    done
  }

  if [[ -n "$argc_json_file" ]]; then
    process_telegram_json "$argc_json_file"
  fi

  if [[ -d "$argc_input_file" ]]; then
    process_directory "$argc_input_file"
    echo "Directory processing completed: $argc_input_file"
    echo "NDJSON files created with _ms_*.jsonl suffix for each processed file"
  else
    create_ndjson "$argc_input_file"
    echo "NDJSON files created with base name: $(basename "${argc_input_file%.*}")_ms_*.jsonl"
  fi
}

# @cmd Default command - clean and deduplicate credential files
# @arg input-file! "Input file or directory to process (recursively processes directories)" [string]
# @arg output-file "Output file or directory (defaults to input_processed)" [string]
# @flag --no-dedupe "Disable deduplication (only clean)" 
# @option -d --dupes-file "Output duplicate lines to this file (implies deduplication)" [string]
# @option -j --json-file "JSON metadata file (optional)" [string]
# @option -c --channel-name "Telegram channel name (optional)" [string]
# @option -a --channel-at "Telegram channel @ handle (optional)" [string]
main() {
  # Set default output if not provided
  if [[ -z "$argc_output_file" ]]; then
    if [[ -d "$argc_input_file" ]]; then
      argc_output_file="${argc_input_file}_processed"
    else
      local dir=$(dirname "$argc_input_file")
      local base=$(basename "$argc_input_file" | sed 's/\.[^.]*$//')
      argc_output_file="${dir}/${base}_processed.txt"
    fi
  fi

  if [[ ! -f "$argc_input_file" && ! -d "$argc_input_file" ]]; then
    echo "Error: Input file or directory '$argc_input_file' not found" >&2
    exit 1
  fi

  process_file() {
    local input_file="$1"
    local output_file="$2"
    local dupes_file="$3"
    
    if [[ "$argc_no_dedupe" == "true" ]]; then
      echo "Cleaning: $input_file -> $output_file" >&2
      perl -ne '
            next unless /[:|]/;
            s/\|/:/g;
            chomp;
            s/\r//g;
            s/\n//g;
            $_ .= "\n";
            print if s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|;
        ' "$input_file" >"$output_file"
    else
      echo "Cleaning and deduplicating: $input_file -> $output_file" >&2
      if [[ -n "$dupes_file" ]]; then
        perl -ne '
                next unless /[:|]/;
                s/\|/:/g;
                chomp;
                s/\r//g;
                s/\n//g;
                $_ .= "\n";
                if (s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|) {
                    if ($seen{$_}++) {
                        print STDERR $_
                    } else {
                        print $_
                    }
                }
            ' "$input_file" >"$output_file" 2>"$dupes_file"
      else
        perl -ne '
                next unless /[:|]/;
                s/\|/:/g;
                chomp;
                s/\r//g;
                s/\n//g;
                $_ .= "\n";
                if (s|^(?:https?://)?(?:www\.)?([^/:]+)(.*?):|$1$2:|) {
                    print unless $seen{$_}++;
                }
            ' "$input_file" >"$output_file"
      fi
    fi
  }

  process_directory() {
    local input_dir="$1"
    local output_dir="$2"
    local dupes_file_base="$3"
    
    echo "Processing directory recursively: $input_dir -> $output_dir" >&2
    
    mkdir -p "$output_dir"
    
    find "$input_dir" -type f -print0 | while IFS= read -r -d '' file; do
      local rel_path="${file#$input_dir/}"
      local rel_dir=$(dirname "$rel_path")
      local filename=$(basename "$rel_path")
      local base_name="${filename%.*}"
      local extension="${filename##*.}"
      
      if [[ "$rel_dir" == "." ]]; then
        local output_file="$output_dir/${base_name}_cleaned.${extension}"
        local current_dupes_file=""
        if [[ -n "$dupes_file_base" ]]; then
          current_dupes_file="$output_dir/${base_name}_dupes.${extension}"
        fi
      else
        mkdir -p "$output_dir/$rel_dir"
        local output_file="$output_dir/$rel_dir/${base_name}_cleaned.${extension}"
        local current_dupes_file=""
        if [[ -n "$dupes_file_base" ]]; then
          current_dupes_file="$output_dir/$rel_dir/${base_name}_dupes.${extension}"
        fi
      fi
      
      process_file "$file" "$output_file" "$current_dupes_file"
    done
  }

  if [[ -d "$argc_input_file" ]]; then
    if [[ -n "$argc_dupes_file" ]]; then
      echo "Warning: --dupes-file option ignored when processing directories (individual dupes files created per input file)" >&2
    fi
    
    process_directory "$argc_input_file" "$argc_output_file" "$argc_dupes_file"
    
    echo "Directory processing completed: $argc_input_file -> $argc_output_file"
  else
    if [[ -n "$argc_dupes_file" ]]; then
      process_file "$argc_input_file" "$argc_output_file" "$argc_dupes_file"
      
      echo "Processed file: $argc_output_file"
      echo "Duplicate lines saved to: $argc_dupes_file"
      echo "Total duplicates removed: $(wc -l <"$argc_dupes_file")"
    else
      process_file "$argc_input_file" "$argc_output_file" ""
      
      echo "Processed file: $argc_output_file"
      if [[ "$argc_no_dedupe" != "true" ]]; then
        echo "Duplicates removed (use --dupes-file to save duplicates to a file)"
      fi
    fi
  fi

  echo "Lines not matching format were ignored"
}

# @cmd Full processing - clean, dedupe, and convert to JSONL in one pass
# @arg input-file! "Input file or directory to process (recursively processes directories)" [string]
# @option -j --json-file "JSON metadata file (optional)" [string]
# @option -c --channel-name "Telegram channel name (optional)" [string]
# @option -a --channel-at "Telegram channel @ handle (optional)" [string]
full() {
  if [[ ! -f "$argc_input_file" && ! -d "$argc_input_file" ]]; then
    echo "Error: Input file or directory '$argc_input_file' not found" >&2
    exit 1
  fi

  # Auto-detect JSON file if not provided and input is a directory
  if [[ -z "$argc_json_file" && -d "$argc_input_file" ]]; then
    local input_dir_name=$(basename "$argc_input_file")
    local parent_dir=$(dirname "$argc_input_file")
    local auto_json_file="${parent_dir}/${input_dir_name}.json"
    
    if [[ -f "$auto_json_file" ]]; then
      argc_json_file="$auto_json_file"
      echo "Auto-detected JSON file: $auto_json_file" >&2
    fi
  fi

  declare -A channel_metadata

  process_telegram_json() {
    local json_file="$1"

    if [[ -n "$json_file" && -f "$json_file" ]]; then
      if ! jq empty "$json_file" 2>/dev/null; then
        echo "Warning: JSON file '$json_file' is not valid JSON, attempting to fix..." >&2

        error_msg=$(jq empty "$json_file" 2>&1 || true)

        if [[ "$error_msg" == *"Invalid numeric literal"* ]]; then
          echo "This appears to be an issue with numeric values in the JSON. Attempting to pre-process the file..." >&2

          local temp_file=$(mktemp)
          sed 's/Infinity/null/g' "$json_file" >"$temp_file"

          if jq empty "$temp_file" 2>/dev/null; then
            echo "Pre-processing successful! Using fixed JSON file." >&2
            json_file="$temp_file"
          else
            rm "$temp_file"
            echo "Pre-processing failed. Will try to extract metadata anyway." >&2
          fi
        fi
      fi

      channel_id=$(jq -r 'keys[0]' "$json_file" 2>/dev/null || echo "")

      if [[ -n "$channel_id" && "$channel_id" != "null" ]]; then
        channel_metadata["id"]=$channel_id

        while IFS= read -r message; do
          file_name=$(echo "$message" | jq -r '.file // empty' 2>/dev/null)
          if [[ -n "$file_name" ]]; then
            base_input=$(basename "$argc_input_file")
            if [[ "$file_name" == *"$base_input"* ]] || [[ "$base_input" == *"$(echo "$file_name" | sed 's/🔒 //' | sed 's/ - @.*//')"* ]]; then
              channel_metadata["date"]=$(echo "$message" | jq -r '.raw.Date // ""' 2>/dev/null)
              channel_metadata["message_content"]=$(echo "$message" | jq -r '.raw.Message // ""' 2>/dev/null)
              channel_metadata["message_id"]=$(echo "$message" | jq -r '.raw.ID // ""' 2>/dev/null)

              if [[ -n "${temp_file:-}" && -f "${temp_file:-}" ]]; then
                rm -f "$temp_file"
              fi

              return 0
            fi
          fi
        done < <(jq -r '.[] | .messages[]? // empty' "$json_file" 2>/dev/null)

        if [[ -n "${temp_file:-}" && -f "${temp_file:-}" ]]; then
          rm -f "$temp_file"
        fi
      fi
    fi

    return 0
  }

  process_file_full() {
    local input_file="$1"
    local original_filename=$(basename "$input_file")
    local ndjson_base="${original_filename%.*}_ms"

    local channel_name="${argc_channel_name:-}"
    local channel_at="${argc_channel_at:-}"

    if [[ -z "$channel_name" ]]; then
      if [[ "$original_filename" =~ @([^-]+) ]]; then
        channel_at="@${BASH_REMATCH[1]}"
        channel_name="${BASH_REMATCH[1]}"
      fi
    fi

    local post_date=""
    if [[ -n "${channel_metadata[date]}" && "${channel_metadata[date]}" != "null" ]]; then
      post_date=$(date -d "@${channel_metadata[date]}" -Iseconds 2>/dev/null || echo "${channel_metadata[date]}")
    fi

    echo "Processing file: $input_file" >&2
    echo "Creating NDJSON files with base name: ${ndjson_base}_*.jsonl" >&2

    # Export metadata as environment variables
    export ULP_ORIGINAL_FILENAME="$original_filename"
    export ULP_NDJSON_BASE="$ndjson_base"
    export ULP_CHANNEL_ID="$channel_id"
    export ULP_CHANNEL_NAME="$channel_name"
    export ULP_CHANNEL_AT="$channel_at"
    export ULP_POST_DATE="$post_date"
    export ULP_MESSAGE_CONTENT="${channel_metadata[message_content]:-}"
    export ULP_MESSAGE_ID="${channel_metadata[message_id]:-}"

    # Process file in 100MB chunks
    perl -ne '
          BEGIN {
              use JSON;
              use POSIX qw(strftime);
              use Encode qw(encode_utf8);

              my $chunk_size = 100 * 1024 * 1024; # 100MB chunks
              my $current_chunk_size = 0;
              my @chunk_lines = ();
              my %seen = ();
              
              my $file_counter = 1;
              my $max_jsonl_size = 100 * 1024 * 1024; # 100MB per JSONL file
              my $current_jsonl_size = 0;
              my $line_count = 0;
              my $valid_line_count = 0;
              my $duplicate_count = 0;

              my $original_filename = $ENV{ULP_ORIGINAL_FILENAME} || "";
              my $ndjson_base = $ENV{ULP_NDJSON_BASE} || "";
              my $channel_id = $ENV{ULP_CHANNEL_ID} || "";
              my $channel_name = $ENV{ULP_CHANNEL_NAME} || "";
              my $channel_at = $ENV{ULP_CHANNEL_AT} || "";
              my $post_date = $ENV{ULP_POST_DATE} || "";
              my $message_content = $ENV{ULP_MESSAGE_CONTENT} || "";
              my $message_id = $ENV{ULP_MESSAGE_ID} || "";

              my $current_ndjson_file = sprintf("%s_%03d.jsonl", $ndjson_base, $file_counter);
              open(my $ndjson_fh, ">:utf8", $current_ndjson_file) or die "Cannot open $current_ndjson_file: $!";
              print STDERR "Created NDJSON file: $current_ndjson_file\n";

              sub new_jsonl_file {
                  close($main::ndjson_fh) if $main::ndjson_fh;
                  $main::file_counter++;
                  my $new_file = sprintf("%s_%03d.jsonl", $main::ndjson_base, $main::file_counter);
                  open($main::ndjson_fh, ">:utf8", $new_file) or die "Cannot open $new_file: $!";
                  $main::current_jsonl_size = 0;
                  print STDERR "Created new JSONL file: $new_file\n";
              }

              sub process_chunk {
                  my $lines_ref = shift;
                  
                  for my $line (@$lines_ref) {
                      my @parts = split /:/, $line;
                      next if @parts < 3;

                      my $url_part = shift @parts;
                      my $username = shift @parts;
                      my $password = join(":", @parts);

                      next unless defined $username && defined $password &&
                                 $username ne "" && $password ne "" &&
                                 $username !~ /^\s*$/ && $password !~ /^\s*$/;

                      my $full_url = $url_part;
                      unless ($full_url =~ m|^https?://|) {
                          $full_url = "https://" . $full_url;
                      }

                      my $doc = {
                          url => $full_url,
                          username => $username,
                          password => $password,
                          metadata => {
                              original_filename => $main::original_filename,
                              telegram_channel_id => $main::channel_id,
                              telegram_channel_name => $main::channel_name,
                              telegram_channel_at => $main::channel_at,
                              date_posted => $main::post_date,
                              message_content => $main::message_content,
                              message_id => $main::message_id
                          }
                      };

                      my $json_line = encode_json($doc) . "\n";
                      my $line_size = length(encode_utf8($json_line));

                      if ($main::current_jsonl_size + $line_size > $main::max_jsonl_size && $main::current_jsonl_size > 0) {
                          new_jsonl_file();
                      }

                      print {$main::ndjson_fh} $json_line;
                      $main::current_jsonl_size += $line_size;
                      $main::valid_line_count++;
                  }
                  
                  @$lines_ref = (); # Clear the chunk
              }

              $main::ndjson_fh = $ndjson_fh;
              $main::current_jsonl_size = $current_jsonl_size;
              $main::max_jsonl_size = $max_jsonl_size;
              $main::original_filename = $original_filename;
              $main::ndjson_base = $ndjson_base;
              $main::channel_id = $channel_id;
              $main::channel_name = $channel_name;
              $main::channel_at = $channel_at;
              $main::post_date = $post_date;
              $main::message_content = $message_content;
              $main::message_id = $message_id;
              $main::file_counter = $file_counter;
              $main::line_count = $line_count;
              $main::valid_line_count = $valid_line_count;
              $main::duplicate_count = $duplicate_count;
          }

          $main::line_count++;

          # Skip lines that dont match format
          next unless /[:|]/;

          # Clean the line
          s/\|/:/g;
          chomp;
          s/\r//g;
          s/\n//g;

          my $cleaned_line = $_;

          # Normalize URL
          if ($cleaned_line =~ /^(https?:\/\/)/) {
              $cleaned_line =~ s|^(https?://)(www\.)?([^/:]+)(.*?):|$3$4:|;
          } elsif ($cleaned_line =~ /^www\./) {
              $cleaned_line =~ s|^www\.([^/:]+)(.*?):|$1$2:|;
          } elsif ($cleaned_line =~ /^([^:\/]+(?:\.[^:\/]+)*)(\/ [^:]*)?:(.*)/) {
              my ($domain, $path, $rest) = ($1, $2 || "", $3);
              $cleaned_line = "$domain$path:$rest";
          } else {
              unless ($cleaned_line =~ /^[^:]+:[^:]+:/) {
                  next;
              }
          }

          # Skip duplicates
          if ($seen{$cleaned_line}++) {
              $main::duplicate_count++;
              next;
          }

          # Add to chunk
          push @chunk_lines, $cleaned_line;
          $current_chunk_size += length($cleaned_line) + 1;

          # Process chunk if it exceeds 100MB
          if ($current_chunk_size >= $chunk_size) {
              process_chunk(\@chunk_lines);
              $current_chunk_size = 0;
          }

          END {
              # Process any remaining lines
              process_chunk(\@chunk_lines) if @chunk_lines;
              
              close($main::ndjson_fh) if $main::ndjson_fh;
              print STDERR "Processed $main::line_count total lines\n";
              print STDERR "Valid credentials: $main::valid_line_count\n";
              print STDERR "Duplicates removed: $main::duplicate_count\n";
          }
      ' <"$input_file"
  }

  process_directory() {
    local input_dir="$1"
    
    echo "Processing directory recursively: $input_dir" >&2
    
    find "$input_dir" -type f -print0 | while IFS= read -r -d '' file; do
      process_file_full "$file"
    done
  }

  if [[ -n "$argc_json_file" ]]; then
    process_telegram_json "$argc_json_file"
  fi

  if [[ -d "$argc_input_file" ]]; then
    process_directory "$argc_input_file"
    echo "Directory processing completed: $argc_input_file"
    echo "NDJSON files created with _ms_*.jsonl suffix for each processed file"
  else
    process_file_full "$argc_input_file"
    echo "NDJSON files created with base name: $(basename "${argc_input_file%.*}")_ms_*.jsonl"
  fi
}

