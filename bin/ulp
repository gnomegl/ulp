#!/usr/bin/env bash

# @describe Clean and deduplicate credential files by normalizing domains
# @arg input-file! "Input file to process" [string]
# @arg output-file! "Output file for cleaned results" [string]
# @option -d --dupes-file "Output duplicate lines to this file (requires --dedupe)" [string]
# @flag   -u --dedupe "Deduplicate lines"
# @meta require-tools perl

# ARGC-BUILD {
# This block was generated by argc (https://github.com/sigoden/argc).
# Modifying it manually is not recommended

_argc_run() {
    if [[ "${1:-}" == "___internal___" ]]; then
        _argc_die "error: unsupported ___internal___ command"
    fi
    if [[ "${OS:-}" == "Windows_NT" ]] && [[ -n "${MSYSTEM:-}" ]]; then
        set -o igncr
    fi
    argc__args=("$(basename "$0" .sh)" "$@")
    argc__positionals=()
    _argc_index=1
    _argc_len="${#argc__args[@]}"
    _argc_tools=()
    _argc_parse
    _argc_require_tools "${_argc_tools[@]}"
    if [ -n "${argc__fn:-}" ]; then
        $argc__fn "${argc__positionals[@]}"
    fi
}

_argc_usage() {
    cat <<-'EOF'
Clean and deduplicate credential files by normalizing domains

USAGE: ulp [OPTIONS] <INPUT-FILE> <OUTPUT-FILE>

ARGS:
  <INPUT-FILE>   "Input file to process" [string]
  <OUTPUT-FILE>  "Output file for cleaned results" [string]

OPTIONS:
  -d, --dupes-file <DUPES-FILE>  "Output duplicate lines to this file (requires --dedupe)" [string]
  -u, --dedupe                   "Deduplicate lines"
  -h, --help                     Print help
  -V, --version                  Print version
EOF
    exit
}

_argc_version() {
    echo ulp 0.0.0
    exit
}

_argc_parse() {
    local _argc_key _argc_action
    local _argc_subcmds=""
    while [[ $_argc_index -lt $_argc_len ]]; do
        _argc_item="${argc__args[_argc_index]}"
        _argc_key="${_argc_item%%=*}"
        case "$_argc_key" in
        --help | -help | -h)
            _argc_usage
            ;;
        --version | -version | -V)
            _argc_version
            ;;
        --)
            _argc_dash="${#argc__positionals[@]}"
            argc__positionals+=("${argc__args[@]:$((_argc_index + 1))}")
            _argc_index=$_argc_len
            break
            ;;
        --dupes-file | -d)
            _argc_take_args "--dupes-file <DUPES-FILE>" 1 1 "-" ""
            _argc_index=$((_argc_index + _argc_take_args_len + 1))
            if [[ -z "${argc_dupes_file:-}" ]]; then
                argc_dupes_file="${_argc_take_args_values[0]:-}"
            else
                _argc_die "error: the argument \`--dupes-file\` cannot be used multiple times"
            fi
            ;;
        --dedupe | -u)
            if [[ "$_argc_item" == *=* ]]; then
                _argc_die "error: flag \`--dedupe\` don't accept any value"
            fi
            _argc_index=$((_argc_index + 1))
            if [[ -n "${argc_dedupe:-}" ]]; then
                _argc_die "error: the argument \`--dedupe\` cannot be used multiple times"
            else
                argc_dedupe=1
            fi
            ;;
        *)
            if _argc_maybe_flag_option "-" "$_argc_item"; then
                _argc_die "error: unexpected argument \`$_argc_key\` found"
            fi
            argc__positionals+=("$_argc_item")
            _argc_index=$((_argc_index + 1))
            ;;
        esac
    done
    _argc_tools=(perl)
    if [[ -n "${_argc_action:-}" ]]; then
        $_argc_action
    else
        if [[ "${argc__positionals[0]:-}" == "help" ]] && [[ "${#argc__positionals[@]}" -eq 1 ]]; then
            _argc_usage
        fi
        _argc_match_positionals 0 0
        local values_index values_size
        IFS=: read -r values_index values_size <<<"${_argc_match_positionals_values[0]:-}"
        if [[ -n "$values_index" ]]; then
            argc_input_file="${argc__positionals[values_index]}"
        else
            _argc_die "error: the required environments \`<INPUT-FILE>\` were not provided"
        fi
        IFS=: read -r values_index values_size <<<"${_argc_match_positionals_values[1]:-}"
        if [[ -n "$values_index" ]]; then
            argc_output_file="${argc__positionals[values_index]}"
        else
            _argc_die "error: the required environments \`<OUTPUT-FILE>\` were not provided"
        fi
    fi
}

_argc_take_args() {
    _argc_take_args_values=()
    _argc_take_args_len=0
    local param="$1" min="$2" max="$3" signs="$4" delimiter="$5"
    if [[ "$min" -eq 0 ]] && [[ "$max" -eq 0 ]]; then
        return
    fi
    local _argc_take_index=$((_argc_index + 1)) _argc_take_value
    if [[ "$_argc_item" == *=* ]]; then
        _argc_take_args_values=("${_argc_item##*=}")
    else
        while [[ $_argc_take_index -lt $_argc_len ]]; do
            _argc_take_value="${argc__args[_argc_take_index]}"
            if _argc_maybe_flag_option "$signs" "$_argc_take_value"; then
                if [[ "${#_argc_take_value}" -gt 1 ]]; then
                    break
                fi
            fi
            _argc_take_args_values+=("$_argc_take_value")
            _argc_take_args_len=$((_argc_take_args_len + 1))
            if [[ "$_argc_take_args_len" -ge "$max" ]]; then
                break
            fi
            _argc_take_index=$((_argc_take_index + 1))
        done
    fi
    if [[ "${#_argc_take_args_values[@]}" -lt "$min" ]]; then
        _argc_die "error: incorrect number of values for \`$param\`"
    fi
    if [[ -n "$delimiter" ]] && [[ "${#_argc_take_args_values[@]}" -gt 0 ]]; then
        local item values arr=()
        for item in "${_argc_take_args_values[@]}"; do
            IFS="$delimiter" read -r -a values <<<"$item"
            arr+=("${values[@]}")
        done
        _argc_take_args_values=("${arr[@]}")
    fi
}

_argc_match_positionals() {
    _argc_match_positionals_values=()
    _argc_match_positionals_len=0
    local params=("$@")
    local args_len="${#argc__positionals[@]}"
    if [[ $args_len -eq 0 ]]; then
        return
    fi
    local params_len=$# arg_index=0 param_index=0
    while [[ $param_index -lt $params_len && $arg_index -lt $args_len ]]; do
        local takes=0
        if [[ "${params[param_index]}" -eq 1 ]]; then
            if [[ $param_index -eq 0 ]] &&
                [[ ${_argc_dash:-} -gt 0 ]] &&
                [[ $params_len -eq 2 ]] &&
                [[ "${params[$((param_index + 1))]}" -eq 1 ]] \
                ; then
                takes=${_argc_dash:-}
            else
                local arg_diff=$((args_len - arg_index)) param_diff=$((params_len - param_index))
                if [[ $arg_diff -gt $param_diff ]]; then
                    takes=$((arg_diff - param_diff + 1))
                else
                    takes=1
                fi
            fi
        else
            takes=1
        fi
        _argc_match_positionals_values+=("$arg_index:$takes")
        arg_index=$((arg_index + takes))
        param_index=$((param_index + 1))
    done
    if [[ $arg_index -lt $args_len ]]; then
        _argc_match_positionals_values+=("$arg_index:$((args_len - arg_index))")
    fi
    _argc_match_positionals_len=${#_argc_match_positionals_values[@]}
    if [[ $params_len -gt 0 ]] && [[ $_argc_match_positionals_len -gt $params_len ]]; then
        local index="${_argc_match_positionals_values[params_len]%%:*}"
        _argc_die "error: unexpected argument \`${argc__positionals[index]}\` found"
    fi
}

_argc_maybe_flag_option() {
    local signs="$1" arg="$2"
    if [[ -z "$signs" ]]; then
        return 1
    fi
    local cond=false
    if [[ "$signs" == *"+"* ]]; then
        if [[ "$arg" =~ ^\+[^+].* ]]; then
            cond=true
        fi
    elif [[ "$arg" == -* ]]; then
        if (( ${#arg} < 3 )) || [[ ! "$arg" =~ ^---.* ]]; then
            cond=true
        fi
    fi
    if [[ "$cond" == "false" ]]; then
        return 1
    fi
    local value="${arg%%=*}"
    if [[ "$value" =~ [[:space:]] ]]; then
        return 1
    fi
    return 0
}

_argc_require_tools() {
    local tool missing_tools=()
    for tool in "$@"; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            missing_tools+=("$tool")
        fi
    done
    if [[ "${#missing_tools[@]}" -gt 0 ]]; then
        echo "error: missing tools: ${missing_tools[*]}" >&2
        exit 1
    fi
}

_argc_die() {
    if [[ $# -eq 0 ]]; then
        cat
    else
        echo "$*" >&2
    fi
    exit 1
}

_argc_run "$@"

# ARGC-BUILD }

if [[ ! -f "$argc_input_file" ]]; then
  echo "Error: Input file '$argc_input_file' not found" >&2
  exit 1
fi

if [[ -n "$argc_dupes_file" && "$argc_dedupe" != 1 ]]; then
  echo "Error: --dupes-file option requires --dedupe flag" >&2
  exit 1
fi

if [[ "$argc_dedupe" == 1 ]]; then
    if [[ -n "$argc_dupes_file" ]]; then
      perl -ne '
          next unless /[:|]/;
          s/\|/:/g;
          chomp;
          s/\r//g;
          s/\n//g;
          $_ .= "\n";
          if (s|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|) {
              if ($seen{$_}++) {
                  print STDERR $_
              } else {
                  print $_
              }
          }
      ' "$argc_input_file" >"$argc_output_file" 2>"$argc_dupes_file"

      echo "Cleaned file: $argc_output_file"
      echo "Duplicate lines saved to: $argc_dupes_file"
      echo "Total duplicates removed: $(wc -l <"$argc_dupes_file")"
      echo "Lines not matching format were ignored"
    else
      perl -ne '
          next unless /[:|]/;
          s/\|/:/g;
          chomp;
          s/\r//g;
          s/\n//g;
          $_ .= "\n";
          if (s|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|) {
              print unless $seen{$_}++;
          }
      ' "$argc_input_file" >"$argc_output_file"

      echo "Cleaned file: $argc_output_file"
      echo "Duplicates removed (use --dupes-file to save duplicates to a file)"
      echo "Lines not matching format were ignored"
    fi
  else
    perl -ne '
        next unless /[:|]/;
        s/\|/:/g;
        chomp;
        s/\r//g;
        s/\n//g;
        $_ .= "\n";
        print if s|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|;
    ' "$argc_input_file" >"$argc_output_file"

    echo "Cleaned file: $argc_output_file (no deduplication)"
    echo "Lines not matching format were ignored"
  fi
