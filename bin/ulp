# This block was generated by argc (https://github.com/sigoden/argc).
# Modifying it manually is not recommended

_argc_run() {
    if [[ "${1:-}" == "___internal___" ]]; then
        _argc_die "error: unsupported ___internal___ command"
    fi
    if [[ "${OS:-}" == "Windows_NT" ]] && [[ -n "${MSYSTEM:-}" ]]; then
        set -o igncr
    fi
    argc__args=("$(basename "$0" .sh)" "$@")
    argc__positionals=()
    _argc_index=1
    _argc_len="${#argc__args[@]}"
    _argc_tools=()
    _argc_parse
    if [ -n "${argc__fn:-}" ]; then
        $argc__fn "${argc__positionals[@]}"
    fi
}

_argc_usage() {
    cat <<-'EOF'
ulp 2.0.0
ULP - URL Line Processor for cleaning, deduplicating, and converting credential files

USAGE: ulp <COMMAND>

COMMANDS:
  clean   Clean and normalize credential files by standardizing domain formats
  dedupe  Deduplicate credential files with optional duplicate output
  jsonl   Convert cleaned credential files to NDJSON/JSONL format for Meilisearch indexing
  main    Default command - clean and deduplicate credential files
  full    Full processing - clean, dedupe, and convert to JSONL in one pass
EOF
    exit
}

_argc_version() {
    echo ulp 2.0.0
    exit
}

_argc_parse() {
    local _argc_key _argc_action
    local _argc_subcmds="clean, dedupe, jsonl, main, full"
    while [[ $_argc_index -lt $_argc_len ]]; do
        _argc_item="${argc__args[_argc_index]}"
        _argc_key="${_argc_item%%=*}"
        case "$_argc_key" in
        --help | -help | -h)
            _argc_usage
            ;;
        --version | -version | -V)
            _argc_version
            ;;
        --)
            _argc_dash="${#argc__positionals[@]}"
            argc__positionals+=("${argc__args[@]:$((_argc_index + 1))}")
            _argc_index=$_argc_len
            break
            ;;
        clean)
            _argc_index=$((_argc_index + 1))
            _argc_action=_argc_parse_clean
            break
            ;;
        dedupe)
            _argc_index=$((_argc_index + 1))
            _argc_action=_argc_parse_dedupe
            break
            ;;
        jsonl)
            _argc_index=$((_argc_index + 1))
            _argc_action=_argc_parse_jsonl
            break
            ;;
        main)
            _argc_index=$((_argc_index + 1))
            _argc_action=_argc_parse_main
            break
            ;;
        full)
            _argc_index=$((_argc_index + 1))
            _argc_action=_argc_parse_full
            break
            ;;
        help)
            local help_arg="${argc__args[$((_argc_index + 1))]:-}"
            case "$help_arg" in
            clean)
                _argc_usage_clean
                ;;
            dedupe)
                _argc_usage_dedupe
                ;;
            jsonl)
                _argc_usage_jsonl
                ;;
            main)
                _argc_usage_main
                ;;
            full)
                _argc_usage_full
                ;;
            "")
                _argc_usage
                ;;
            *)
                _argc_die "error: invalid value \`$help_arg\` for \`<command>\`"$'\n'"  [possible values: $_argc_subcmds]"
                ;;
            esac
            ;;
        *)
            _argc_die "error: \`ulp\` requires a subcommand but one was not provided"$'\n'"  [subcommands: $_argc_subcmds]"
            ;;
        esac
    done
    if [[ -n "${_argc_action:-}" ]]; then
        $_argc_action
    else
        argc__fn=main
        if [[ "${argc__positionals[0]:-}" == "help" ]] && [[ "${#argc__positionals[@]}" -eq 1 ]]; then
            _argc_usage
        fi
    fi
}

