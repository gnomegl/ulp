#!/bin/bash

input_file=""
output_file=""
dedupe=false
show_dupes=false
dupes_file=""

usage() {
  echo "Usage: $0 -i input_file -o output_file [-u] [-d dupes_file]"
  echo "  -i: Input file"
  echo "  -o: Output file"
  echo "  -u: Deduplicate lines (optional)"
  echo "  -d: Output duplicate lines to this file (optional, requires -u)"
  exit 1
}

while getopts "i:o:d:uh" opt; do
  case $opt in
  i)
    input_file="$OPTARG"
    ;;
  o)
    output_file="$OPTARG"
    ;;
  u)
    dedupe=true
    ;;
  d)
    show_dupes=true
    dupes_file="$OPTARG"
    ;;
  h)
    usage
    ;;
  \?)
    echo "Invalid option: -$OPTARG" >&2
    usage
    ;;
  esac
done

if [[ -z "$input_file" || -z "$output_file" ]]; then
  echo "Error: Input and output files are required"
  usage
fi

if [[ ! -f "$input_file" ]]; then
  echo "Error: Input file '$input_file' not found"
  exit 1
fi

if [[ "$show_dupes" == true && "$dedupe" != true ]]; then
  echo "Error: -d option requires -u (deduplicate) option"
  usage
fi

if [[ "$dedupe" == true ]]; then
  if [[ "$show_dupes" == true ]]; then
    perl -ne '
        s|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|;
        if ($seen{$_}++) {
            print STDERR $_
        } else {
            print $_
        }
    ' "$input_file" >"$output_file" 2>"$dupes_file"

    echo "Cleaned file: $output_file"
    echo "Duplicate lines saved to: $dupes_file"
    echo "Total duplicates removed: $(wc -l <"$dupes_file")"
  else
    perl -ne 's|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|; print unless $seen{$_}++' "$input_file" >"$output_file"
    echo "Cleaned file: $output_file"
    echo "Duplicates removed (use -d to save duplicates to a file)"
  fi
else
  perl -ne 's|^(?:https?://)?(?:www\.)?([^/]+)(?:/[^:]*)?:|$1:|; print' "$input_file" >"$output_file"
  echo "Cleaned file: $output_file (no deduplication)"
fi
